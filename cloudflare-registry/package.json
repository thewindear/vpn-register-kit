{
  "name": "vpn-register-kit-cloudflare-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "cf:token:create": "node scripts/create-token.js",
    "cf:token:list": "node scripts/list-tokens.js",
